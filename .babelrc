{
  "presets": [
    ["next/babel", {
      "preset-env": {
        "targets": {
          "chrome": "80",
          "firefox": "78",
          "safari": "14",
          "edge": "80"
        },
        "bugfixes": true,
        "shippedProposals": true,
        "modules": false,
        "exclude": [
          "transform-async-to-generator",
          "transform-regenerator",
          "transform-for-of"
        ]
      }
    }]
  ]
}
